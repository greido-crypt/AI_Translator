# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Build/test artifacts
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
dist/
build/
*.egg-info/

# IDE/editor files
.idea/
.vscode/
*.iml

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Runtime/temp logs
*.log
tmp/
temp/

# Project outputs (metrics, reports, generated samples, history)
outputs/*
!outputs/.gitkeep

# Large model checkpoints and training artifacts
checkpoints/
**/checkpoints/
**/checkpoint-*/
*.safetensors
*.bin
*.pt
*.pth

# Local docs/drafts
*.docx
