{
  "model_name": "Helsinki-NLP/opus-mt-en-ru",
  "dataset_name": "opus100",
  "local_dataset_path": "configs/synthetic_8000_rich_cases.json",
  "use_local_dataset_only": true,
  "lang_pair": "en-ru",
  "source_lang": "en",
  "target_lang": "ru",
  "output_dir": "./outputs/checkpoints_synth8000",
  "max_train_samples": 6200,
  "max_eval_samples": 700,
  "max_test_samples": 700,
  "max_source_length": 192,
  "max_target_length": 192,
  "max_source_chars": 2200,
  "max_target_chars": 2400,
  "use_technical_filter": true,
  "technical_min_keyword_hits": 1,
  "enable_noise_augmentation": true,
  "noise_augmentation_ratio": 0.15,
  "learning_rate": 1.2e-5,
  "per_device_train_batch_size": 8,
  "per_device_eval_batch_size": 8,
  "num_train_epochs": 4,
  "weight_decay": 0.01,
  "warmup_ratio": 0.06,
  "logging_steps": 100,
  "eval_strategy": "epoch",
  "save_strategy": "epoch",
  "predict_with_generate": true,
  "fp16": true,
  "seed": 42,
  "force_cuda": true,
  "bf16": false,
  "stabilization_epochs": 0.8,
  "stabilization_learning_rate": 4.0e-6
}
