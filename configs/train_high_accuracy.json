{
  "model_name": "Helsinki-NLP/opus-mt-en-ru",
  "dataset_name": "opus100",
  "lang_pair": "en-ru",
  "source_lang": "en",
  "target_lang": "ru",
  "output_dir": "./outputs/checkpoints_highacc",
  "local_dataset_path": "configs/synthetic_8000_rich_cases.json",
  "use_local_dataset_only": true,
  "max_train_samples": 5800,
  "max_eval_samples": 1000,
  "max_test_samples": 1000,
  "max_source_length": 196,
  "max_target_length": 196,
  "max_source_chars": 2200,
  "max_target_chars": 2200,
  "use_technical_filter": false,
  "enable_noise_augmentation": true,
  "noise_augmentation_ratio": 0.18,
  "learning_rate": 8e-6,
  "per_device_train_batch_size": 8,
  "per_device_eval_batch_size": 8,
  "num_train_epochs": 4,
  "weight_decay": 0.01,
  "warmup_ratio": 0.08,
  "logging_steps": 100,
  "eval_strategy": "epoch",
  "save_strategy": "epoch",
  "predict_with_generate": true,
  "fp16": true,
  "bf16": false,
  "stabilization_epochs": 1.0,
  "stabilization_learning_rate": 3e-6,
  "seed": 42,
  "force_cuda": true
}
