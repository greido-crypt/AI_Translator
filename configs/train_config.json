{
  "model_name": "Helsinki-NLP/opus-mt-en-ru",
  "dataset_name": "opus100",
  "lang_pair": "en-ru",
  "source_lang": "en",
  "target_lang": "ru",
  "output_dir": "./outputs/checkpoints",
  "max_train_samples": 10000,
  "max_eval_samples": 1500,
  "max_test_samples": 1500,
  "max_source_length": 128,
  "max_target_length": 128,
  "max_source_chars": 1400,
  "max_target_chars": 1400,
  "use_technical_filter": true,
  "technical_min_keyword_hits": 1,
  "technical_keywords": [
    "api",
    "http",
    "https",
    "request",
    "response",
    "server",
    "client",
    "frontend",
    "backend",
    "database",
    "sql",
    "nosql",
    "cache",
    "caching",
    "logging",
    "authentication",
    "authorization",
    "timeout",
    "exception",
    "token",
    "endpoint",
    "parser",
    "compiler",
    "runtime",
    "framework",
    "microservice",
    "json",
    "yaml",
    "xml",
    "docker",
    "kubernetes"
  ],
  "enable_noise_augmentation": true,
  "noise_augmentation_ratio": 0.12,
  "learning_rate": 1e-05,
  "per_device_train_batch_size": 8,
  "per_device_eval_batch_size": 8,
  "num_train_epochs": 2,
  "weight_decay": 0.01,
  "warmup_ratio": 0.06,
  "logging_steps": 100,
  "eval_strategy": "epoch",
  "save_strategy": "epoch",
  "predict_with_generate": true,
  "fp16": true,
  "seed": 42,
  "force_cuda": true,
  "bf16": false,
  "stabilization_epochs": 0.5,
  "stabilization_learning_rate": 5e-06
}
